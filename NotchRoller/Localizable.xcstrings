    "about.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An eye-care reminder tool in the notch area\nReminds you to rest your eyes, drink water, and move around"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un outil de rappel pour le soin des yeux dans la zone de l'encoche\nVous rappelle de reposer vos yeux, boire de l'eau et vous lever"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ノッチエリアのアイケアリマインダーツール\n目を休め、水分を補給し、体を動かすのをサポート"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一款基于刘海区域的护眼提醒工具\n定时提醒你休息眼睛、喝水、活动身体"
          }
        }
      }
    },
